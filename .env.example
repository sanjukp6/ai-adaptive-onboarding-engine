# SkillBridge Environment Variables
# Copy this file to .env and fill in the values

# Vite dev server port (optional, default 5173)
VITE_PORT=5173

# Gemini API Key for AI-powered skill extraction (optional — can also be entered in the UI)
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Add any future API keys or config here
# VITE_API_URL=https://api.example.com
